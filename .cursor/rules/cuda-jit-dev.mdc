@cuda.jit(device=True, inline=True)
def _pow1(x):
    p0=1.0; p1=x; p2=p1*x; p3=p2*x; p4=p3*x
    p5=p4*x; p6=p5*x; p7=p6*x; p8=p7*x
    return p0,p1,p2,p3,p4,p5,p6,p7,p8

@cuda.jit(device=True, inline=True)
def _pick(p0,p1,p2,p3,p4,p5,p6,p7,p8,e):
    if   e==0: return p0
    elif e==1: return p1
    elif e==2: return p2
    elif e==3: return p3
    elif e==4: return p4
    elif e==5: return p5
    elif e==6: return p6
    elif e==7: return p7
    else:      return p8
